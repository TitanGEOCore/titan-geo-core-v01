generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                    String    @id
  shop                  String
  state                 String
  isOnline              Boolean   @default(false)
  scope                 String?
  expires               DateTime?
  accessToken           String
  userId                BigInt?
  firstName             String?
  lastName              String?
  email                 String?
  accountOwner          Boolean   @default(false)
  locale                String?
  collaborator          Boolean?  @default(false)
  emailVerified         Boolean?  @default(false)
  refreshToken          String?
  refreshTokenExpires   DateTime?

  @@index([shop])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String   // Hashed password
  role         String   @default("Viewer") // Admin, Editor, Viewer
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model ShopSettings {
  id              String   @id @default(cuid())
  shop            String   @unique
  brandVoice      String   @default("")
  targetAudience  String   @default("")
  noGos           String   @default("")
  planOverride    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UsageTracker {
  id          String   @id @default(cuid())
  shop        String
  module      String   // Module type: geo_optimization, alt_text_generation, meta_generation
  productId   String?  // Optional - can be null for aggregate tracking
  optimizedAt DateTime @default(now())

  @@index([shop])
  @@index([shop, module])
  @@index([shop, productId])
  @@index([shop, module, optimizedAt])
}

model ExternalTokens {
  id            String   @id @default(cuid())
  shop          String   @unique
  gscRefresh    String?
  merchantRefresh String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContentVersion {
  id           String   @id @default(cuid())
  shop         String
  productId    String
  previousData String
  newData      String
  createdAt    DateTime @default(now())

  @@index([shop, productId])
}

model ShopAnalysisReport {
  id               String   @id @default(cuid())
  shop             String
  overallScore     Int      @default(0)
  criticalProducts String?  // JSON array of products with issues
  fullReport       String   // Full AI analysis result as JSON
  createdAt        DateTime @default(now())

  @@index([shop])
  @@index([shop, createdAt])
}
